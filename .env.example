# Admin password (change before production)
ADMIN_PASSWORD=your-secure-password-here

# Session token for admin cookie (use a long random string)
ADMIN_SESSION_TOKEN=change-this-to-a-long-random-string

# Email notifications (optional — logs to console if not set)
RESEND_API_KEY=
EMAIL_FROM=OfficeMitra <noreply@theofficemitra.com>
ADMIN_EMAIL=admin@theofficemitra.com

# Public site URL for SEO and emails
NEXT_PUBLIC_SITE_URL=https://theofficemitra.com

# Postgres (required for production on Vercel — expert requests, community, feedback)
# Vercel Postgres, Neon, or Supabase connection string:
POSTGRES_URL=
# Alternative name some providers use:
# DATABASE_URL=

# Intelligence Engine (Python worker)
INTELLIGENCE_WORKER_URL=http://localhost:8080
INTELLIGENCE_API_KEY=change-me-long-random-key
OPENAI_API_KEY=
